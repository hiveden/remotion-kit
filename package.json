{
  "name": "@hiveden/remotion-kit",
  "version": "0.0.0",
  "private": true,
  "description": "Remotion clip tooling — agent-shaped brief composer + preview + LLM-powered scaffolding.",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "dev": "next dev --webpack -p ${PORT:-3200}",
    "build": "next build --webpack",
    "start": "next start -p ${PORT:-3200}",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run --passWithNoTests",
    "check:secrets": "! grep -rnE '(sk-[A-Za-z0-9]{20,}|sk-proj-)' --include='*.ts' --include='*.tsx' --include='*.js' --include='*.json' --include='*.md' --include='*.yaml' --include='*.yml' --include='.env*' --exclude-dir=node_modules --exclude-dir=.next --exclude-dir=dist --exclude-dir=.git . | grep -v 'secret-allow:'",
    "check:purity": "! grep -rnE '\\b(episode|shot|series|pipeline)\\b' --include='*.ts' --include='*.tsx' --include='*.md' --exclude-dir=node_modules --exclude-dir=tests --exclude-dir=docs --exclude-dir=.workspace --exclude-dir=.next --exclude-dir=dist . | grep -v 'purity-allow:'",
    "check": "bun run typecheck && bun run lint && bun run check:purity && bun run check:secrets"
  },
  "dependencies": {
    "@remotion/cli": "4.0.438",
    "@remotion/player": "4.0.438",
    "next": "16.0.0-beta.0",
    "openai": "^5.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.438",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "lefthook": "^1.13.0",
    "oxlint": "^1.20.0",
    "vitest": "^4.0.0"
  }
}
