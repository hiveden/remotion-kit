# LLM endpoint (OpenAI-compatible).
# Default: local CPA proxy. Override for direct OpenAI.
OPENAI_BASE_URL=http://localhost:8317/v1

# API key. With CPA the placeholder is fine; for direct OpenAI use your real key.
OPENAI_API_KEY=cpa-local

# Default model id (CPA mirrors OpenAI model names).
# Available via CPA: gpt-5.5 / gpt-5.4 / gpt-5.4-mini / gpt-5.3-codex / gpt-5.3-codex-spark
OPENAI_MODEL=gpt-5.5

# When 1, llm-client returns canned fixture responses instead of calling the API.
# Used by tests and the offline dev path. See tests/__fixtures__/llm/.
MOCK_LLM=0

# Per-call token cap.
OPENAI_MAX_TOKENS=4096
